    {
      "name": "products",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"products\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"title\" TEXT NOT NULL, \"author\" TEXT NOT NULL, \"isbn\" TEXT NOT NULL, \"category\" TEXT NOT NULL, \"price\" INTEGER NOT NULL, \"publisher\" TEXT NOT NULL, \"product_id\" TEXT NOT NULL UNIQUE, \"internal_pricing\" INTEGER NOT NULL, \"self_encoding\" TEXT NOT NULL UNIQUE, \"purchase_price\" INTEGER NOT NULL, \"publication_year\" INTEGER NOT NULL, \"retail_discount\" INTEGER NOT NULL DEFAULT 10000, \"wholesale_discount\" INTEGER NOT NULL DEFAULT 10000, \"wholesale_price\" INTEGER NOT NULL, \"member_discount\" INTEGER NOT NULL DEFAULT 10000, \"purchase_sale_mode\" TEXT NOT NULL, \"bookmark\" TEXT NOT NULL, \"packaging\" TEXT NOT NULL, \"properity\" TEXT NOT NULL, \"statistical_class\" TEXT NOT NULL, \"operator\" TEXT NOT NULL, \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"updated_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), CHECK (price >= 0), CHECK (internal_pricing >= 0), CHECK (purchase_price >= 0), CHECK (publication_year BETWEEN 0 AND 9999), CHECK (retail_discount BETWEEN 0 AND 10000), CHECK (wholesale_discount BETWEEN 0 AND 10000), CHECK (wholesale_price >= 0), CHECK (member_discount BETWEEN 0 AND 10000));"
        }
      ]
    },
    {
      "name": "users",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"users\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"username\" TEXT NOT NULL UNIQUE, \"password\" TEXT NOT NULL, \"email\" TEXT NULL, \"phone\" TEXT NULL, \"name\" TEXT NULL, \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"updated_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"role\" TEXT NOT NULL, \"salt\" TEXT NOT NULL, \"status\" INTEGER NOT NULL DEFAULT 1, CHECK (status BETWEEN 0 AND 3));"
        }
      ]
    }
