Project bookstore_management_system_current {
  database_type: "SQLite"
  Note: "Generated from current Drift table definitions on 2026-04-03."
}

Table users {
  id integer [pk, increment]
  username text [not null, unique]
  password text [not null]
  email text
  phone text
  name text
  created_at integer [not null, note: "Drift DateTimeColumn, stored as unix epoch seconds in SQLite"]
  updated_at integer [not null, note: "Drift DateTimeColumn, stored as unix epoch seconds in SQLite"]
  role text [not null]
  salt text [not null]
  status integer [not null, default: 0, note: "0=inactive, 1=active, 2=suspended, 3=deleted"]
}

Table products {
  id integer [pk, increment]
  title text [not null]
  author text [not null]
  isbn text [not null]
  category text [not null]
  price real [not null]
  publisher text [not null]
  product_id text [not null, note: "Current business code field"]
  internal_pricing real [not null]
  self_encoding text [not null, note: "Current internal encoding field"]
  purchase_price real [not null]
  publication_year integer [not null]
  retail_discount real [not null]
  wholesale_discount real [not null]
  wholesale_price real [not null]
  member_discount real [not null]
  purchase_sale_mode text [not null]
  bookmark text [not null, note: "Current shelf marker / location style field"]
  packaging text [not null]
  properity text [not null, note: "Typo kept to match current code"]
  statistical_class text [not null]
  operator text [not null, note: "Currently stores username, not a user foreign key"]
  created_at integer [not null, note: "Drift DateTimeColumn, stored as unix epoch seconds in SQLite"]
  updated_at integer [not null, note: "Drift DateTimeColumn, stored as unix epoch seconds in SQLite"]
}
